# Copy to /srv/issueq/instances/<owner-repo>/env.
# Then set ownership and permissions:
#   sudo chown issueq:issueq /srv/issueq/instances/<owner-repo>/env
#   sudo chmod 0600 /srv/issueq/instances/<owner-repo>/env

# GitHub token used by github.token_env in issueq.yaml.
# Use a least-privilege repository-scoped token or GitHub App installation token.
GITHUB_TOKEN=replace_me

# Optional: ensure bare job commands resolve predictably.
# PATH=/usr/local/bin:/usr/bin:/bin

# Optional variables consumed by your own agent scripts can go here.
# ISSUEQ_AGENT_LOG_LEVEL=info
